{
  "name": "@sebse-tools/ics-parser",
  "version": "1.0.0",
  "type": "module",
  "description": "Full RFC 5545 iCalendar implementation. Parse, prepare, expand, and query .ics data with complete RRULE support, DST-aware timezone resolution, and serialize/deserialize caching",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "demo": "node --inspect dist/demo.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "generate-readme": "node ../../scripts/generate-readme.ts"
  },
  "dependencies": {
    "luxon": "^3.7.2",
    "windows-iana": "^5.1.0"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.12.2",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "license": "AGPL-3.0-only"
}
