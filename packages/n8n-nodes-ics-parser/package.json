{
  "name": "n8n-nodes-ics-parser",
  "version": "3.0.2",
  "description": "n8n node to parse ICS calendar files and query events",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": {
    "name": "sebse"
  },
  "scripts": {
    "build": "tsc -b && cpy 'src/nodes/IcsParser/ics-parser.svg' dist/nodes/IcsParser/ics-parser.svg --base=cwd",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "demo": "node --inspect dist/demo.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "generate-readme": "node ../../scripts/generate-readme.ts"
  },
  "dependencies": {
    "@sebse-tools/ics-parser": "workspace:*"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "cpy-cli": "^7.0.0",
    "n8n-workflow": "*",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependenciesMeta": {
    "n8n-workflow": {
      "optional": true
    }
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/IcsParser/IcsParser.node.js"
    ]
  },
  "license": "AGPL-3.0-only"
}
