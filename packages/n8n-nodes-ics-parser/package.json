{
  "name": "@sebse-tools/n8n-nodes-ics-parser",
  "version": "1.1.3",
  "description": "n8n node to parse ICS calendar files and query events",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": {
    "name": "sebse"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "demo": "node --inspect dist/demo.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "generate-readme": "node ../../scripts/generate-readme.ts"
  },
  "dependencies": {
    "@sebse-tools/ics-parser": "workspace:*",
    "n8n-workflow": "2.16.0"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/IcsParser/IcsParser.node.js"
    ]
  },
  "license": "AGPL-3.0-only"
}
